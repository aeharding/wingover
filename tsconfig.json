{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "useDefineForClassFields": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "types": ["vite/client", "node", "apple-mapkit"]
  },
  "include": ["src", "e2e", "vite.config.ts", "playwright.config.ts"],
  // src/sw.ts is a worker module (webworker lib); vite-plugin-pwa builds it.
  "exclude": ["src/sw.ts"]
}
