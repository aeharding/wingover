opt_out_usage

default_platform(:ios)

APP_IDENTIFIER = "app.wingover.wingover"

platform :ios do
  desc "Build via tauri ios build, export manually, push to TestFlight"
  lane :deploy do
    setup_ci if ENV["CI"]
    # Installs the shared distribution cert + profile into the CI keychain.
    # Cert only. The PROFILE is fetched from the developer portal each run
    # (below): profiles go stale whenever the App ID gains a capability, and
    # the CI token cannot write a regenerated one back to the match cache —
    # its push 403s (observed 2026-07-15, when Sign in with Apple landed, and
    # the "fixed" profile silently evaporated after one green run). Apple is
    # the source of truth for profiles; the git cache holds only the cert.
    match(
      type: "appstore",
      app_identifier: APP_IDENTIFIER,
      api_key_path: "authkey.json",
      skip_provisioning_profiles: true,
    )

    # Pinned to the name export-options.plist maps to. readonly: false is the
    # self-healing part — when a future capability invalidates the portal
    # profile, sigh repairs it in place instead of failing the build.
    get_provisioning_profile(
      app_identifier: APP_IDENTIFIER,
      api_key_path: "authkey.json",
      provisioning_name: "match AppStore app.wingover.wingover",
      ignore_profiles_with_different_name: true,
      readonly: false,
    )

    build_number = ENV.fetch("BUILD_NUMBER", "1")
    root = File.expand_path("..", __dir__)

    # tauri ios build owns the archive (frontend build + xcodebuild with the
    # context its Rust phase expects), but its export step insists on cloud
    # signing, which our API key cannot do — tolerate that failure and
    # export the archive ourselves with the match profile.
    sh("cd '#{root}' && pnpm tauri ios build " \
       "--export-method app-store-connect --build-number #{build_number} " \
       "|| true")

    archive = File.join(root, "src-tauri/gen/apple/build/wingover_iOS.xcarchive")
    UI.user_error!("Archive missing: tauri build failed before export — check its log above") unless File.directory?(archive)

    export_dir = File.join(root, "build-export")
    sh("xcodebuild -exportArchive " \
       "-archivePath '#{archive}' " \
       "-exportOptionsPlist '#{File.join(root, "fastlane/export-options.plist")}' " \
       "-exportPath '#{export_dir}'")

    ipa = Dir[File.join(export_dir, "*.ipa")].first
    UI.user_error!("No IPA produced by exportArchive") unless ipa

    # Internal-first: internal testers can install the moment processing
    # finishes, no Beta App Review. External distribution (a "Public Testers"
    # group + distribute_external: true) comes back when there's a public
    # beta to run — it needs the group to exist AND a review pass per build.
    upload_to_testflight(
      ipa: ipa,
      app_identifier: APP_IDENTIFIER,
      api_key_path: "authkey.json",
      changelog: "GitHub Actions build #{build_number}, ref #{ENV['GITHUB_REF']}, sha #{ENV['GITHUB_SHA']}, msg #{ENV['COMMIT_MSG']}",
    )
  end
end
