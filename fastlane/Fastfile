opt_out_usage

default_platform(:ios)

APP_IDENTIFIER = "app.wingover.wingover"

platform :ios do
  desc "Build via tauri ios build and push to TestFlight"
  lane :deploy do
    setup_ci if ENV["CI"]
    # Installs the shared distribution cert (+ profile) into the CI keychain.
    match(
      type: "appstore",
      app_identifier: APP_IDENTIFIER,
      api_key_path: "authkey.json",
    )

    build_number = ENV.fetch("BUILD_NUMBER", "1")

    # tauri ios build owns the archive: it runs beforeBuildCommand (frontend
    # build) and invokes xcodebuild with the context its Rust build phase
    # expects — driving the Xcode project directly with gym aborts inside
    # xcode-script. Signing auth comes from APPLE_API_* env (workflow).
    sh("cd .. && pnpm tauri ios build " \
       "--export-method app-store-connect --build-number #{build_number}")

    upload_to_testflight(
      ipa: "src-tauri/gen/apple/build/arm64/Wingover.ipa",
      app_identifier: APP_IDENTIFIER,
      api_key_path: "authkey.json",
      changelog: "GitHub Actions build #{build_number}, sha #{ENV['GITHUB_SHA']}",
    )
  end
end
